{
  "expo": {
    "name": "YapLin",
    "slug": "yaplin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "yaplin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.anonymous.yaplin"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash-icon.png"
        }
      ],
      "expo-font",
      "./plugins/withNotificationQueries.js",
      "./plugins/withForegroundListener.js",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c38edae3-3d8e-4d7e-9c6f-fb3f54966fc9"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/c38edae3-3d8e-4d7e-9c6f-fb3f54966fc9"
    }
  }
}
