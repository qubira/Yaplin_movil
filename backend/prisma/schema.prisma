generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  supervisor
  cajero
}

enum StoreStatus {
  active
  inactive
}

model Business {
  id        String   @id @default(cuid())
  name      String
  ruc       String?
  createdAt DateTime @default(now())

  users  User[]
  stores Store[]
}

model User {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  email        String   @unique
  passwordHash String
  name         String
  initials     String
  role         Role
  storeId      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Store {
  id         String      @id @default(cuid())
  businessId String
  business   Business    @relation(fields: [businessId], references: [id])
  name       String
  address    String?
  account    String?
  status     StoreStatus @default(active)
  methods    String[]
  createdAt  DateTime    @default(now())

  transactions Transaction[]
}

model Transaction {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  payerName     String
  payerInitials String
  amount        Decimal  @db.Decimal(10, 2)
  method        String
  timestamp     DateTime
  reference     String
  status        String   @default("confirmed")
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
}
